// Prisma Schema - 笔记数据库
// 学习点：Prisma 模型定义自动生成 TypeScript 类型

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String[] // PostgreSQL 数组类型
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tags])
  @@index([createdAt])
}
